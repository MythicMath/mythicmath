APP_ENV=local
API_PORT=8000

POSTGRES_USER=mythic
POSTGRES_PASSWORD=mythic
POSTGRES_DB=mythicmath
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://mythic:mythic@db:5432/mythicmath

REDIS_URL=redis://redis:6379/0
SESSION_TTL_SECONDS=86400
SESSION_BACKEND=memory

# Comma-separated OAuth client IDs from Google Cloud Console.
GOOGLE_CLIENT_IDS=
